---
import '../styles/global.css';
import AGIGauge from '../components/AGIGauge.tsx';
import ProgressChart from '../components/ProgressChart.tsx';
import liveData from '../data/live.json';

const data = liveData as any;
const AGI_READINESS = data.agiReadiness ?? data.agiIndex ?? 0;
const agiDistance = data.agiDistance ?? null;
const benchmarks = data.benchmarks ?? [];
const dimensions = data.dimensions ?? [];
const bottleneckDimension = data.bottleneckDimension ?? null;
const pendingBenchmarks = data.pendingBenchmarks ?? [];
const eta = data.eta ?? {};
const updatedAt = data.updatedAt;
const chartHistory = (data.history ?? []).map((point: any) => ({
  date: point.date,
  index: point.agiReadiness ?? point.index ?? 0,
}));
const trajectorySamples = chartHistory.length;
const samplesNeeded = Math.max(30 - trajectorySamples, 0);
const base = import.meta.env.BASE_URL;
const assetBase = base.endsWith('/') ? base : `${base}/`;
const siteUrl = 'https://brayanjeshua.github.io/agi-clock/';
const updatedLabel = new Date(updatedAt).toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});
const lowestBenchmarks = [...benchmarks]
  .filter((b: any) => typeof b.score === 'number')
  .sort((a: any, b: any) => a.score - b.score)
  .slice(0, 3);
const etaLabel =
  eta.status === 'estimated'
    ? `Estimated ${eta.year}`
    : eta.status === 'trend_unclear'
      ? 'Trend unclear'
      : 'Collecting baseline';

const trendLabel = (trend: string) => {
  if (trend === 'up') return { text: 'Improving', color: '#2f8f5b' };
  if (trend === 'down') return { text: 'Falling', color: '#d44a35' };
  if (trend === 'flat') return { text: 'Flat', color: '#b87816' };
  return { text: 'New signal', color: '#007f89' };
};
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="AGI Clock is an open-source benchmark tracker for estimating AI progress toward AGI across reasoning, engineering, autonomy, and tool-use signals."
    />
    <title>AGI Clock — Open-source AGI progress tracker</title>
    <link rel="icon" type="image/svg+xml" href={`${assetBase}favicon.svg`} />
    <meta property="og:title" content="AGI Clock — Open-source AGI progress tracker" />
    <meta
      property="og:description"
      content="A clean public dashboard that estimates AGI readiness from daily LLM Stats benchmark data."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="AGI Clock" />
    <meta
      name="twitter:description"
      content="Open-source tracker of AI benchmark progress toward Artificial General Intelligence."
    />
    <link rel="sitemap" href={`${assetBase}sitemap-index.xml`} />
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'AGI Clock',
      url: siteUrl,
      description: 'Open-source tracker of AI benchmark progress toward Artificial General Intelligence.',
      author: { '@type': 'Person', name: 'Brayan Jeshua', url: 'https://brayanjeshua.com' },
    })} />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={base} aria-label="AGI Clock home">
        <span class="brand-mark">AGI</span>
        <span>Clock</span>
      </a>
      <nav class="nav-links" aria-label="Primary navigation">
        <a href="#benchmarks">Benchmarks</a>
        <a href="#method">Method</a>
        <a href="https://github.com/brayanjeshua/agi-clock" target="_blank" rel="noopener">GitHub</a>
      </nav>
    </header>

    <main>
      <section class="hero">
        <div class="hero-copy">
          <p class="eyebrow">Open-source AGI progress tracker</p>
          <h1>AGI Clock</h1>
          <p class="lede">
            A public instrument for estimating how far frontier AI still is from AGI across reasoning, engineering,
            autonomy, tool use, search, and reliability signals.
          </p>
          <p class="notice">Benchmark proxy only. This does not claim AGI has been reached.</p>
          <div class="hero-actions">
            <a class="button primary" href="#live-index">View live index</a>
            <a class="button secondary" href="https://github.com/brayanjeshua/agi-clock" target="_blank" rel="noopener">
              Star on GitHub
            </a>
          </div>
          <dl class="hero-metrics" aria-label="AGI Clock summary">
            <div>
              <dt>AGI Readiness</dt>
              <dd>{AGI_READINESS}%</dd>
            </div>
            <div>
              <dt>Distance</dt>
              <dd>{agiDistance ?? '—'}%</dd>
            </div>
            <div>
              <dt>Bottleneck</dt>
              <dd>{bottleneckDimension?.name ?? 'Collecting'}</dd>
            </div>
          </dl>
        </div>

        <div class="instrument-panel" id="live-index" aria-label="Live AGI index preview">
          <div class="panel-bar">
            <span>Live readiness proxy</span>
            <span class="status-dot">Updated daily</span>
          </div>
          <AGIGauge value={AGI_READINESS} label="AGI READINESS" subLabel="MULTI-DIMENSION" client:load />
          <div class="panel-foot">
            <span>{etaLabel}</span>
            <span>Updated {updatedLabel}</span>
          </div>
        </div>
      </section>

      <section class="section split-section" aria-labelledby="why-title">
        <div>
          <p class="eyebrow">Why it exists</p>
          <h2 id="why-title">A stricter scoreboard for a noisy question.</h2>
        </div>
        <div class="benefit-grid">
          <article>
            <span>01</span>
            <h3>No single benchmark decides it</h3>
            <p>Combines 24 daily LLM Stats signals instead of letting one saturated leaderboard declare victory.</p>
          </article>
          <article>
            <span>02</span>
            <h3>Autonomy matters</h3>
            <p>Weights agentic work, computer use, planning, tools, and search because AGI must do more than answer tests.</p>
          </article>
          <article>
            <span>03</span>
            <h3>Easy to audit</h3>
            <p>Static site, public data file, MIT license, and a collector script that can be inspected or improved.</p>
          </article>
        </div>
      </section>

      <section class="section" id="benchmarks" aria-labelledby="benchmarks-title">
        <div class="section-heading">
          <p class="eyebrow">Current signal</p>
          <h2 id="benchmarks-title">{benchmarks.length} benchmarks, four dimensions, one readiness proxy.</h2>
          <p>
            Each benchmark reports the best available frontier score from LLM Stats. The index groups those raw scores
            into capability dimensions and keeps the ETA hidden until the new formula has enough daily history.
          </p>
        </div>

        <div class="dimension-grid" aria-label="AGI readiness dimensions">
          {dimensions.map((dimension: any) => (
            <article>
              <div class="score-line">
                <strong>{dimension.name}</strong>
                <span>{dimension.score ?? '—'}%</span>
              </div>
              <div class="meter" aria-label={`${dimension.name} readiness ${dimension.score ?? 0}%`}>
                <span style={`width: ${Math.min(dimension.score ?? 0, 100)}%`}></span>
              </div>
              <p>{dimension.description}</p>
            </article>
          ))}
        </div>

        <div class="benchmark-list">
          {benchmarks.map((b: any) => {
            const trend = trendLabel(b.trend);
            return (
              <article class="benchmark-row">
                <div class="benchmark-main">
                  <span class="category">{b.category}</span>
                  <h3>{b.name}</h3>
                  <p>{b.description}</p>
                </div>
                <div class="benchmark-score">
                  <div class="score-line">
                    <span>Best {b.score}%</span>
                    <span>{b.modelName ?? 'Unknown model'}</span>
                  </div>
                  <div class="meter" aria-label={`${b.name} frontier score ${b.score}%`}>
                    <span style={`width: ${Math.min(b.score ?? 0, 100)}%`}></span>
                  </div>
                  <div class="score-line small">
                    <span>{b.source}</span>
                    <span style={`color: ${trend.color}`}>{trend.text}</span>
                  </div>
                </div>
              </article>
            );
          })}
        </div>
      </section>

      <section class="section visual-section" aria-labelledby="chart-title">
        <div class="chart-card">
          <div class="section-heading compact">
            <p class="eyebrow">Trajectory</p>
            <h2 id="chart-title">New formula baseline</h2>
            <p>
              Daily v2 history started now. The chart shows the first baseline point and waits for 30 samples before
              estimating a trend.
            </p>
          </div>
          <div class="trajectory-panel" aria-label="AGI readiness trajectory baseline">
            <div>
              <span>Current</span>
              <strong>{AGI_READINESS}%</strong>
              <small>{chartHistory.at(-1)?.date ?? updatedLabel}</small>
            </div>
            <div>
              <span>Distance</span>
              <strong>{agiDistance ?? '—'}%</strong>
              <small>remaining</small>
            </div>
            <div>
              <span>ETA</span>
              <strong>{etaLabel}</strong>
              <small>{samplesNeeded > 0 ? `${samplesNeeded} daily samples needed` : 'ready to estimate'}</small>
            </div>
          </div>
          <div class="trajectory-track" aria-hidden="true">
            <span style={`width: ${Math.min(AGI_READINESS, 100)}%`}></span>
            <i style={`left: ${Math.min(AGI_READINESS, 100)}%`}></i>
          </div>
          <ProgressChart history={chartHistory} client:load />
        </div>
        <aside class="snapshot-card" aria-label="AGI readiness bottleneck snapshot">
          <p class="eyebrow">Snapshot</p>
          <h2>Bottleneck: {bottleneckDimension?.name ?? 'Collecting'}</h2>
          <div class="snapshot-list">
            {lowestBenchmarks.map((b: any) => (
              <div>
                <strong>{b.name}</strong>
                <span>{b.category} · {b.score}% · {b.modelName ?? 'Unknown model'}</span>
              </div>
            ))}
          </div>
        </aside>
      </section>

      <section class="section method-section" id="method" aria-labelledby="method-title">
        <div class="section-heading">
          <p class="eyebrow">Method</p>
          <h2 id="method-title">Transparent enough to disagree with.</h2>
          <p>
            AGI Clock estimates distance to AGI with a frontier benchmark basket. It is not a claim of consciousness,
            economic replacement, or that a single model has passed every task.
          </p>
        </div>
        <div class="method-steps">
          <div>
            <strong>Collect</strong>
            <span>Daily frontier benchmark data from the llm-stats.com API.</span>
          </div>
          <div>
            <strong>Normalize</strong>
            <span>Group raw scores into reasoning, engineering, autonomy, and tool/search dimensions.</span>
          </div>
          <div>
            <strong>Publish</strong>
            <span>Show readiness, distance, bottleneck, and hold ETA until enough v2 history exists.</span>
          </div>
        </div>
        <div class="pending-note">
          Pending daily sources: {pendingBenchmarks.map((b: any) => b.name).join(', ')}.
        </div>
      </section>

      <section class="cta-section">
        <div>
          <p class="eyebrow">Built in public</p>
          <h2>Use it, fork it, or challenge the benchmarks.</h2>
          <p>AGI Clock is intentionally small: static frontend, auditable data, and room for better benchmark proposals.</p>
        </div>
        <a class="button primary" href="https://github.com/brayanjeshua/agi-clock" target="_blank" rel="noopener">
          Open repository
        </a>
      </section>
    </main>

    <footer class="site-footer">
      <span>AGI Clock · MIT License · Data from llm-stats.com</span>
      <span>Built by <a href="https://brayanjeshua.com" target="_blank" rel="noopener">Brayan Jeshua</a></span>
    </footer>
  </body>
</html>
