---
import '../styles/global.css';
import AGIGauge from '../components/AGIGauge.tsx';
import ProgressChart from '../components/ProgressChart.tsx';
import liveData from '../data/live.json';

const { agiIndex: AGI_INDEX, benchmarks, eta, updatedAt, history } = liveData;
const base = import.meta.env.BASE_URL;
const assetBase = base.endsWith('/') ? base : `${base}/`;
const siteUrl = 'https://brayanjeshua.github.io/agi-clock/';
const updatedLabel = new Date(updatedAt).toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});
const exceededCount = benchmarks.filter((b: any) => b.trend === 'exceeded').length;
const topBenchmarks = [...benchmarks]
  .sort((a: any, b: any) => b.progress - a.progress)
  .slice(0, 3);

const trendLabel = (trend: string) => {
  if (trend === 'exceeded') return { text: 'Threshold met', color: '#2f8f5b' };
  if (trend === 'fast') return { text: 'Moving fast', color: '#d44a35' };
  return { text: 'Moving slowly', color: '#b87816' };
};
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="AGI Clock is an open-source benchmark tracker for measuring AI progress toward expert-human performance."
    />
    <title>AGI Clock — Open-source AGI progress tracker</title>
    <link rel="icon" type="image/svg+xml" href={`${assetBase}favicon.svg`} />
    <meta property="og:title" content="AGI Clock — Open-source AGI progress tracker" />
    <meta
      property="og:description"
      content="A clean public dashboard that tracks AI benchmark progress toward expert-human thresholds."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="AGI Clock" />
    <meta
      name="twitter:description"
      content="Open-source tracker of AI benchmark progress toward Artificial General Intelligence."
    />
    <link rel="sitemap" href={`${assetBase}sitemap-index.xml`} />
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'AGI Clock',
      url: siteUrl,
      description: 'Open-source tracker of AI benchmark progress toward Artificial General Intelligence.',
      author: { '@type': 'Person', name: 'Brayan Jeshua', url: 'https://brayanjeshua.com' },
    })} />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={base} aria-label="AGI Clock home">
        <span class="brand-mark">AGI</span>
        <span>Clock</span>
      </a>
      <nav class="nav-links" aria-label="Primary navigation">
        <a href="#benchmarks">Benchmarks</a>
        <a href="#method">Method</a>
        <a href="https://github.com/brayanjeshua/agi-clock" target="_blank" rel="noopener">GitHub</a>
      </nav>
    </header>

    <main>
      <section class="hero">
        <div class="hero-copy">
          <p class="eyebrow">Open-source AGI progress tracker</p>
          <h1>AGI Clock</h1>
          <p class="lede">
            A public instrument for watching frontier AI systems move toward expert-human performance across reasoning,
            coding, science, engineering, mathematics, and knowledge benchmarks.
          </p>
          <div class="hero-actions">
            <a class="button primary" href="#live-index">View live index</a>
            <a class="button secondary" href="https://github.com/brayanjeshua/agi-clock" target="_blank" rel="noopener">
              Star on GitHub
            </a>
          </div>
          <dl class="hero-metrics" aria-label="AGI Clock summary">
            <div>
              <dt>AGI Index</dt>
              <dd>{AGI_INDEX}%</dd>
            </div>
            <div>
              <dt>Benchmarks met</dt>
              <dd>{exceededCount}/{benchmarks.length}</dd>
            </div>
            <div>
              <dt>Updated</dt>
              <dd>{updatedLabel}</dd>
            </div>
          </dl>
        </div>

        <div class="instrument-panel" id="live-index" aria-label="Live AGI index preview">
          <div class="panel-bar">
            <span>Live composite index</span>
            <span class="status-dot">Updated daily</span>
          </div>
          <AGIGauge value={AGI_INDEX} client:load />
          <div class="panel-foot">
            {
              AGI_INDEX >= 100
                ? 'All tracked expert-human thresholds are currently met.'
                : `Estimated AGI arrival: ${eta.year ?? 'not enough data'}`
            }
          </div>
        </div>
      </section>

      <section class="section split-section" aria-labelledby="why-title">
        <div>
          <p class="eyebrow">Why it exists</p>
          <h2 id="why-title">A simple scoreboard for a noisy question.</h2>
        </div>
        <div class="benefit-grid">
          <article>
            <span>01</span>
            <h3>Benchmark grounded</h3>
            <p>Uses explicit expert-human thresholds instead of vibes, press cycles, or model launch hype.</p>
          </article>
          <article>
            <span>02</span>
            <h3>Broad by design</h3>
            <p>Tracks multiple capability families so a single saturated leaderboard does not dominate the signal.</p>
          </article>
          <article>
            <span>03</span>
            <h3>Easy to audit</h3>
            <p>Static site, public data file, MIT license, and a collector script that can be inspected or improved.</p>
          </article>
        </div>
      </section>

      <section class="section" id="benchmarks" aria-labelledby="benchmarks-title">
        <div class="section-heading">
          <p class="eyebrow">Current signal</p>
          <h2 id="benchmarks-title">Six benchmarks, one capped composite index.</h2>
          <p>
            Each benchmark reports the best known AI score against a published expert-human baseline. Progress is capped
            at 100% before weighting.
          </p>
        </div>

        <div class="benchmark-list">
          {benchmarks.map((b: any) => {
            const trend = trendLabel(b.trend);
            return (
              <article class="benchmark-row">
                <div class="benchmark-main">
                  <span class="category">{b.category}</span>
                  <h3>{b.name}</h3>
                  <p>{b.description}</p>
                </div>
                <div class="benchmark-score">
                  <div class="score-line">
                    <span>AI {b.aiScore}%</span>
                    <span>Human {b.humanExpertScore}%</span>
                  </div>
                  <div class="meter" aria-label={`${b.name} progress ${b.progress}%`}>
                    <span style={`width: ${Math.min(b.progress, 100)}%`}></span>
                  </div>
                  <div class="score-line small">
                    <span>{b.progress}% of threshold</span>
                    <span style={`color: ${trend.color}`}>{trend.text}</span>
                  </div>
                </div>
              </article>
            );
          })}
        </div>
      </section>

      <section class="section visual-section" aria-labelledby="chart-title">
        <div class="chart-card">
          <div class="section-heading compact">
            <p class="eyebrow">Trajectory</p>
            <h2 id="chart-title">Historical index and projection</h2>
          </div>
          <ProgressChart history={history} client:load />
        </div>
        <aside class="snapshot-card" aria-label="Leading benchmark snapshot">
          <p class="eyebrow">Snapshot</p>
          <h2>What is already over the line?</h2>
          <div class="snapshot-list">
            {topBenchmarks.map((b: any) => (
              <div>
                <strong>{b.name}</strong>
                <span>{b.category} · {b.progress}%</span>
              </div>
            ))}
          </div>
        </aside>
      </section>

      <section class="section method-section" id="method" aria-labelledby="method-title">
        <div class="section-heading">
          <p class="eyebrow">Method</p>
          <h2 id="method-title">Transparent enough to disagree with.</h2>
          <p>
            AGI Clock defines the threshold narrowly: expert-human performance on all tracked benchmarks at the same
            time. It is not a claim of consciousness, agency, or economic replacement.
          </p>
        </div>
        <div class="method-steps">
          <div>
            <strong>Collect</strong>
            <span>Daily benchmark data from the llm-stats.com API.</span>
          </div>
          <div>
            <strong>Normalize</strong>
            <span>Convert each score to progress against its expert-human threshold.</span>
          </div>
          <div>
            <strong>Publish</strong>
            <span>Commit static JSON and rebuild a fast public site.</span>
          </div>
        </div>
      </section>

      <section class="cta-section">
        <div>
          <p class="eyebrow">Built in public</p>
          <h2>Use it, fork it, or challenge the benchmarks.</h2>
          <p>AGI Clock is intentionally small: static frontend, auditable data, and room for better benchmark proposals.</p>
        </div>
        <a class="button primary" href="https://github.com/brayanjeshua/agi-clock" target="_blank" rel="noopener">
          Open repository
        </a>
      </section>
    </main>

    <footer class="site-footer">
      <span>AGI Clock · MIT License · Data from llm-stats.com</span>
      <span>Built by <a href="https://brayanjeshua.com" target="_blank" rel="noopener">Brayan Jeshua</a></span>
    </footer>
  </body>
</html>
